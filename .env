# ═══════════════════════════════════════════════════════
#  ChatRoom – environment variables
#  Fill this in before running docker-compose up
# ═══════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=chatroom
DB_USERNAME=root
DB_PASSWORD=root

# ── SSL Certificate ─────────────────────────────────────
# These passwords are used both when generating the cert and when running the app
# If you change them, they must match on both sides
SSL_KEY_ALIAS=chatroom
SSL_KEY_STORE_PASSWORD=chatroom123
SSL_KEY_PASSWORD=chatroom123

# ── JWT ─────────────────────────────────────────────────
# Can be any long random string (min 32 characters)
JWT_SIGNING_KEY=mojSuperTajniJwtKljucKojiJeDovoljnoDugacak123456

# ── Gmail (for 2FA email verification) ──────────────────
# Use a Gmail App Password (not your real password!)
# How to get one: Google Account → Security → 2-Step Verification → App passwords
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Google OAuth2 (optional for local testing) ──────────
# If you don't have credentials, leave empty – the app will still start
# but Google login will not work
GOOGLE_CLIENT_ID=dummy-client-id
GOOGLE_CLIENT_SECRET=dummy-client-secret